{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build main",
      "command": "g++",
      "type": "shell",
      "args": [
        "main.cpp",
        "Circle/Circle.cpp",
        "ClockHand/ClockHand.cpp",
        "DeltaTimer/DeltaTimer.cpp",
        "Drawer/Drawer.cpp",
        "Projection/Projection.cpp",
        "Program/Program.cpp",
        "-I.",
        "-o",
        ".build/main",
        "-lSDL2"
      ],
      "group": "build"
    },
    {
      "label": "Run main",
      "type": "shell",
      "command": "./.build/main",
      "dependsOn": "Build main",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}