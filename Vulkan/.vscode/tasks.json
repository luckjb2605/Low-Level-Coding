{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Current Project",
      "type": "shell",
      "command": "g++",
      "args": [
        "${fileDirname}/*.cpp",
        "-o",
        "${workspaceFolder}/.build/${fileDirnameBasename}",

        // c warnings and debug
        "-std=c++20",
        "-Wall",
        "-Wextra",
        "-Wshadow",
        "-Wconversion",
        "-Wnull-dereference",
        "-pedantic",
        "-g",

        // vulkan
        "-IC:/VulkanSDK/1.4.350.0/Include",
        "-IC:/Users/Lucas/Documents/Visual Studio Code/Libraries/glfw-3.4.bin.WIN64/include",
        "-IC:/Users/Lucas/Documents/Visual Studio Code/Libraries/glm-1.0.3",
        "-LC:/VulkanSDK/1.4.350.0/Lib",
        "-LC:/Users/Lucas/Documents/Visual Studio Code/Libraries/glfw-3.4.bin.WIN64/lib-mingw-w64",
        "-lvulkan-1",
        "-lglfw3",

        // windows
        "-lgdi32",
        "-luser32",
        "-lshell32",
        // "l-opengl32"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Run Current Project",
      "type": "shell",
      "command": "./.build/${fileDirnameBasename}",
      "dependsOn": "Build Current Project",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}