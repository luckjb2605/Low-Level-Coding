{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build SnakeGame v2",
      "command": "g++",
      "type": "shell",
      "args": [
        "Main.cpp",
        "Board/Board.cpp",
        "Food/Food.cpp",
        "TextureManager/TextureManager.cpp",
        "Snake/Snake.cpp",
        "Snake/BodyPart.cpp",
        "Game/Game.cpp",
        "-I.",
        "-o",
        ".build/SnakeGameV2",
        "-lraylib",
        "-lopengl32",
        "-lgdi32",
        "-lwinmm"
      ],
      "group": "build"
    },
    {
      "label": "Run SnakeGame v2",
      "type": "shell",
      "command": "./.build/SnakeGameV2",
      "dependsOn": "Build SnakeGame v2",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
